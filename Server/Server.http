  "productName": "Air Zoom Alpha",
  "sku": "AZA-1001",
  "quantity": 2,
  "courierId": "JNT-77821",
  "customerName": "Juan Dela Cruz",
  "customerAddress": "Blk 7 Lot 12, Quezon City"
}

###

# Backward-compatible legacy route
